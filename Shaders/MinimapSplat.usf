// Parameters
StructuredBuffer<float4> EntityData;
RWTexture2D<float4> OutSortedEntityDataTexture;
float2 RegionMin;
float2 RegionSize;
int NumEntities;

float Directions(int32_t Index)
{
    static const float DirectionArray[16] = { 0, 22.5, 45, 67.5, 90, 112.5, 135, 157.5, 180, 202.5, 225, 247.5, 270, 292.5, 315, 337.5 };
    return DirectionArray[Index];
}
